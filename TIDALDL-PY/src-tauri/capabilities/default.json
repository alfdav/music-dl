{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for music-dl desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "process:allow-restart",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/music-dl-server",
          "sidecar": true
        }
      ]
    },
    "shell:allow-open"
  ]
}
