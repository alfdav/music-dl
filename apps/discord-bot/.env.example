# Discord Bot Configuration
# All variables are REQUIRED — bot refuses to start if any are missing.

# Discord bot authentication token (from Developer Portal)
DISCORD_TOKEN=

# Discord application ID (from Developer Portal)
DISCORD_APPLICATION_ID=

# Guild (server) ID the bot is restricted to
ALLOWED_GUILD_ID=

# Text channel ID the bot listens in
ALLOWED_CHANNEL_ID=

# User ID of the single authorized user
ALLOWED_USER_ID=

# Base URL of the music-dl backend (e.g., http://127.0.0.1:8765)
MUSIC_DL_BASE_URL=

# Bearer token for backend API authentication
MUSIC_DL_BOT_TOKEN=
